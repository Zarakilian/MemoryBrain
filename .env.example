# CORE — required
BRAIN_PORT=7741
OLLAMA_URL=http://ollama:11434

# AUTHENTICATION (optional — if unset, all endpoints are open)
# Set to any random string to require X-Brain-Key header on all requests
BRAIN_API_KEY=

# PLUGIN: Confluence (optional — brain skips if absent)
CONFLUENCE_URL=
CONFLUENCE_TOKEN=

# PLUGIN: PagerDuty (optional)
PAGERDUTY_TOKEN=

# PLUGIN: ClickHouse (optional)
CLICKHOUSE_IOM_URL=
CLICKHOUSE_TOKEN=
